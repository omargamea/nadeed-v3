---
// src/pages/magazine/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const issues = await getCollection('magazine', e => !e.data.draft);
  return issues.map(issue => ({
    params: { slug: issue.slug },
    props:  { issue },
  }));
}

interface Props {
  issue: CollectionEntry<'magazine'>;
}

const { issue }   = Astro.props;
const { Content }  = await issue.render();
const { title, issueNumber, description, publishedAt, coverImage } = issue.data;

const formattedDate = new Intl.DateTimeFormat('ar-EG', {
  year: 'numeric', month: 'long',
}).format(new Date(publishedAt));
---

<BaseLayout
  title={`${title} — مجلة نضيد`}
  description={description}
  ogImage={coverImage}
>
  <!-- Magazine Issue Hero -->
  <div class="nd-mag-strip" style="padding:3.5rem 0">
    <div class="nd-container">
      <nav class="nd-breadcrumb" aria-label="مسار التنقل">
        <a href="/">الرئيسية</a>
        <span class="sep" aria-hidden="true">›</span>
        <a href="/magazine/">مجلة نضيد</a>
        <span class="sep" aria-hidden="true">›</span>
        <span style="color:rgba(250,250,247,.6)">العدد {issueNumber}</span>
      </nav>

      <p style="font-family:var(--fe);font-size:10.5px;letter-spacing:.2em;color:var(--gold);direction:ltr;margin-bottom:.5rem">
        NADEED REVIEW · ISSUE {String(issueNumber).padStart(2, '0')} · {formattedDate}
      </p>
      <h1 style="font-family:var(--fa);font-size:clamp(24px,4vw,46px);color:var(--ivory);line-height:1.3;margin-bottom:.8rem;font-weight:400">
        {title}
      </h1>
      <p style="font-size:14px;color:rgba(250,250,247,.48);max-width:60ch;line-height:1.9">
        {description}
      </p>
    </div>
  </div>

  <!-- Cover Image -->
  {coverImage && (
    <div style="max-width:820px;margin:0 auto;border-radius:0 0 10px 10px;overflow:hidden">
      <img src={coverImage} alt={`غلاف مجلة نضيد العدد ${issueNumber}`} style="width:100%;max-height:420px;object-fit:cover" loading="eager" />
    </div>
  )}

  <!-- Content -->
  <div class="nd-reading-wrap">
    <article class="nd-body-prose">
      <Content />
    </article>

    <!-- Back -->
    <div style="text-align:center;margin-top:3rem;padding-top:2rem;border-top:1px solid var(--parchment)">
      <a href="/magazine/" class="nd-btn-primary">← جميع الأعداد</a>
    </div>
  </div>
</BaseLayout>
