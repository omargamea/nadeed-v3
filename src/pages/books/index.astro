---
// src/pages/books/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCard from '../../components/BookCard.astro';
import { getCollection } from 'astro:content';

const allBooks = await getCollection('books', e => !e.data.draft);
const categories = ['الكل', 'رواية', 'قصة قصيرة', 'شعر', 'فكر', 'نقد', 'معرفة'];
---

<BaseLayout
  title="الإصدارات — نضيد"
  description="إصدارات نضيد في الرواية والقصة القصيرة والشعر والفكر والنقد — دار الأدب والفكر والمعرفة."
>
  <!-- Page Hero -->
  <div class="nd-page-hero">
    <div class="nd-page-hero-inner">
      <span class="nd-page-tag">نضيد</span>
      <h1 class="nd-page-title">الإصدارات</h1>
    </div>
  </div>

  <section class="nd-section">
    <div class="nd-container">

      <!-- Category Filters -->
      <div class="nd-cats-bar" id="bookCatsBar" role="group" aria-label="تصفية حسب التصنيف">
        {categories.map((cat, i) => (
          <button
            class={`nd-cat-btn${i === 0 ? ' active' : ''}`}
            data-cat={cat}
            type="button"
          >
            {cat}
          </button>
        ))}
      </div>

      {allBooks.length > 0
        ? (
          <div class="nd-posts-grid" id="booksGrid">
            {allBooks.map(book => (
              <div class="nd-book-item" data-category={book.data.category}>
                <BookCard book={book} />
              </div>
            ))}
          </div>
        )
        : (
          <div class="nd-empty">
            <p class="nd-empty-icon" aria-hidden="true">📚</p>
            <p>لا توجد إصدارات منشورة بعد.</p>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .nd-cats-bar {
    display: flex;
    align-items: center;
    gap: .6rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }
  .nd-cat-btn {
    padding: .44rem 1rem;
    border-radius: 30px;
    border: 1px solid var(--parchment);
    font-size: 13px;
    font-family: var(--fu);
    color: var(--ink-soft);
    background: var(--white);
    cursor: pointer;
    transition: all var(--ease);
  }
  .nd-cat-btn:hover,
  .nd-cat-btn.active {
    background: var(--red);
    border-color: var(--red);
    color: var(--white);
  }
  .nd-book-item { display: contents; }
  .nd-book-item[hidden] { display: none; }
</style>

<script>
  const bar   = document.getElementById('bookCatsBar')!;
  const items = document.querySelectorAll<HTMLElement>('.nd-book-item');
  const grid  = document.getElementById('booksGrid');

  bar.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.nd-cat-btn');
    if (!btn || !grid) return;

    bar.querySelectorAll('.nd-cat-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    const cat = btn.dataset.cat ?? 'الكل';
    let visible = 0;

    items.forEach(item => {
      const match = cat === 'الكل' || item.dataset.category === cat;
      item.hidden = !match;
      if (match) visible++;
    });

    let emptyEl = grid.querySelector<HTMLElement>('.nd-filter-empty');
    if (visible === 0) {
      if (!emptyEl) {
        emptyEl = document.createElement('div');
        emptyEl.className = 'nd-filter-empty nd-empty';
        emptyEl.innerHTML = `<p>لا توجد إصدارات في تصنيف "${cat}".</p>`;
        grid.appendChild(emptyEl);
      }
    } else {
      emptyEl?.remove();
    }
  });
</script>
