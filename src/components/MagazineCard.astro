---
// src/components/MagazineCard.astro
import type { CollectionEntry } from 'astro:content';

export interface Props {
  issue: CollectionEntry<'magazine'>;
}

const { issue } = Astro.props;
const { title, issueNumber, description, publishedAt, coverImage } = issue.data;

const formattedDate = new Intl.DateTimeFormat('ar-EG', {
  year: 'numeric', month: 'long',
}).format(new Date(publishedAt));
---

<a href={`/magazine/${issue.slug}/`} class="nd-book-card" aria-label={`مجلة نضيد العدد ${issueNumber}: ${title}`}>
  <div class="nd-book-cover">
    {coverImage
      ? <img src={coverImage} alt={`غلاف العدد ${issueNumber}`} loading="lazy" />
      : (
        <div style="width:100%;height:100%;background:linear-gradient(135deg,var(--ink),#2a2016);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem;padding:1.5rem">
          <span style="font-family:var(--fa);font-size:19px;color:var(--ivory);font-weight:700">مجلة نضيد</span>
          <span style="font-family:var(--fe);font-size:11px;letter-spacing:.2em;color:var(--gold);direction:ltr">ISSUE {String(issueNumber).padStart(2,'0')}</span>
          <span style="width:36px;height:1px;background:rgba(201,162,39,.35)"></span>
          <span style="font-family:var(--fa);font-size:12px;color:rgba(250,250,247,.42);text-align:center;line-height:1.55">{formattedDate}</span>
        </div>
      )
    }
  </div>
  <div class="nd-book-body">
    <p class="nd-book-cat" style="direction:ltr">العدد {String(issueNumber).padStart(2,'0')} · {formattedDate}</p>
    <h3 class="nd-book-title">{title}</h3>
    <p class="nd-book-desc">{description}</p>
    <span class="nd-book-cta">تصفّح العدد ←</span>
  </div>
</a>
